        </mxCell>

        <!-- v1 comparison note -->
        <mxCell id="note" value="v1 → v2 change:  In v1, categories were fixed per action class.&#xa;In v2, categories are dynamically resolved from (action_class, confidence, domain_slider).&#xa;Hard-ASK classes remain immutable: no slider, no meta-loop, no user can override them." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#9E9E9E;align=left;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="280" y="960" width="640" height="55" as="geometry" />
