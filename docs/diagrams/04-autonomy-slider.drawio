        <mxCell id="e8" style="endArrow=classic;html=1;strokeWidth=2" edge="1" parent="1" source="suggest" target="exec-suggest">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e9" style="endArrow=classic;html=1;strokeWidth=2" edge="1" parent="1" source="ask" target="exec-ask">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e10" style="endArrow=classic;html=1;strokeWidth=2" edge="1" parent="1" source="exec-safe" target="actuator">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e11" style="endArrow=classic;html=1;strokeWidth=2" edge="1" parent="1" source="exec-suggest" target="actuator">
          <mxGeometry relative="1" as="geometry" />
