        <!-- Boundary contract -->
        <mxCell id="boundary" value="Boundary Contract (unchanged in v2)&#xa;&#xa;1. Adapter signs every WorldEvent with its plugin keypair.&#xa;2. Adapter consumes Actions and returns ActionResult.&#xa;3. No shared state — neither side writes to the other's DB.&#xa;4. Independent failure domains — OpenClaw down ≠ CoreMind down.&#xa;&#xa;v2 additions: Slider promotion proposals routed through approval workflow.&#xa;Investigation escalations delivered as rich notifications with evidence." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#9E9E9E;align=left;fontSize=10;verticalAlign=top;spacingLeft=8;spacingTop=5" vertex="1" parent="1">
          <mxGeometry x="40" y="710" width="780" height="140" as="geometry" />
        </mxCell>

