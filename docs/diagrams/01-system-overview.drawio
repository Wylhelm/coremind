<mxfile host="app.diagrams.net" modified="2026-05-27T00:00:00.000Z" agent="coremind-docs" version="24.0.0">
  <diagram name="System Overview (v2)" id="sys-overview-v2">
    <mxGraphModel dx="1400" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="CoreMind v2 — Nine Cognitive Layers (L0–L8)" style="text;html=1;align=center;verticalAlign=middle;fontSize=22;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="800" height="40" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="Forward flow L0 → L7. Meta-loop L8 observes &amp; tunes L2–L7. Reflection L7 feeds back to L2/L3." style="text;html=1;align=center;verticalAlign=middle;fontSize=12;fontStyle=2" vertex="1" parent="1">
          <mxGeometry x="300" y="58" width="800" height="20" as="geometry" />
        </mxCell>

        <!-- L0 — Discovery (NEW, teal) -->
        <mxCell id="L0" value="L0 — Discovery (NEW)&#xa;mDNS · HA scan · Plugin manifests · UPnP&#xa;→ CapabilityRegistry" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2F1;strokeColor=#00695C;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="420" y="100" width="360" height="70" as="geometry" />
        </mxCell>

        <!-- External sources -->
        <mxCell id="ext-sources" value="External Signals&#xa;(HA, IMAP, webhooks, sensors,&#xa;Tapo, weather, Firefly, …)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECEFF1;strokeColor=#546E7A;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="60" y="195" width="240" height="65" as="geometry" />
        </mxCell>

        <!-- L1 — Perception (blue) -->
        <mxCell id="L1" value="L1 — Perception&#xa;Plugins → signed WorldEvents → EventBus" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="420" y="200" width="360" height="55" as="geometry" />
        </mxCell>

        <!-- L2 — World Model (green) -->
        <mxCell id="L2" value="L2 — World Model (Enhanced)&#xa;Entities · Relationships · Property history&#xa;+ Embedding computation · Snapshot diffing&#xa;(SurrealDB)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="420" y="280" width="360" height="80" as="geometry" />
        </mxCell>

        <!-- L3 — Memory (green) -->
        <mxCell id="L3" value="L3 — Memory (Enhanced)&#xa;Episodic · Semantic (Qdrant) · Procedural&#xa;+ Snapshot embeddings · Similarity queries" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="420" y="385" width="360" height="70" as="geometry" />
        </mxCell>

        <!-- L4 — Reasoning (orange) -->
        <mxCell id="L4" value="L4 — Reasoning ✅  (30 min)&#xa;LLM (mistral-large-3:675b) — patterns · anomalies · predictions&#xa;+ Compressed prompts (~2.5K tokens) · Auto-investigation triggers" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#E65100;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="420" y="480" width="360" height="80" as="geometry" />
        </mxCell>

        <!-- L5 — Intention (orange) -->
        <mxCell id="L5" value="L5 — Intention  (1h)&#xa;Self-prompting → grounded Intents&#xa;salience ≥ 0.45 · confidence ≥ 0.55&#xa;+ Unified action routing via actuator surface" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#E65100;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="420" y="585" width="360" height="80" as="geometry" />
        </mxCell>

        <!-- L6 — Action (red) -->
        <mxCell id="L6" value="L6 — Action&#xa;Autonomy Slider: resolve_agency(class, confidence, slider)&#xa;Unified Actuator · Signed + journaled (audit.log)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="420" y="690" width="360" height="80" as="geometry" />
        </mxCell>

        <!-- L7 — Reflection (purple) -->
        <mxCell id="L7" value="L7 — Reflection ✅  (24h)&#xa;Meta-cognition · Calibration · Rule learning&#xa;+ Graduation proposals for autonomy sliders" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#6A1B9A;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="420" y="795" width="360" height="70" as="geometry" />
        </mxCell>

        <!-- L8 — Meta (NEW, magenta) -->
        <mxCell id="L8" value="L8 — Meta (NEW)&#xa;Observe L2–L7 · Evaluate thresholds · Learn policies · Tune params&#xa;Hard safety boundaries: can NEVER touch hard_ask, secrets, audit, itself" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#880E4F;fontSize=12;fontStyle=1" vertex="1" parent="1">
