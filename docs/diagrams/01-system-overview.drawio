        <!-- Legend -->
        <mxCell id="legend" value="Legend&#xa;&#xa;  teal = Discovery (L0, NEW)       orange = Cognition (L4/L5)&#xa;  blue = Perception (L1)             red = Action (L6)&#xa;  green = State (L2/L3)              purple = Reflection (L7)&#xa;  magenta = Meta (L8, NEW)           dashed = feedback / control&#xa;&#xa;  Solid arrows = forward data flow   Dashed = feedback or control signals" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#9E9E9E;align=left;fontSize=10;verticalAlign=top;spacingLeft=8;spacingTop=5" vertex="1" parent="1">
