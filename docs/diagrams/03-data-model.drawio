        <mxCell id="ent-fields" value="• type : Person | Room | Device | Project …&#xa;• id : stable within type&#xa;• display_name&#xa;• properties : Map&lt;str, Property&gt;&#xa;  – value, unit, confidence, last_updated&#xa;• created_at / updated_at&#xa;• source_plugins : []" style="text;html=1;align=left;verticalAlign=top;fontSize=11;spacingLeft=10" vertex="1" parent="1">
