        <!-- Persistence note -->
        <mxCell id="store-note" value="Persistence&#xa;  • WorldEvent / Entity / Relationship / Intent / Action → SurrealDB&#xa;  • Action → also audit.log (signed, hash-chained)&#xa;  • Semantic memory → Qdrant vectors&#xa;  • InvestigationRun / MetaObservation / AdjustmentRecord → SurrealDB&#xa;  • DeviceCapabilities → capability_registry.json&#xa;  • Embedding vectors → Qdrant snapshot_embeddings (768d, cosine)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#9E9E9E;align=left;fontSize=10" vertex="1" parent="1">
